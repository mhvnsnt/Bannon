{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "types": ["electron-vite/node"],
    "paths": {
      "@main/*": ["./electron/main/*"]
    }
  },
  "include": ["electron.vite.config.*", "electron/**/*"]
}
