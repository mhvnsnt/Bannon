# BANNON daemon deploy config.
# Railway: set PORT automatically; no other vars required to run.
#
# Optional cloud persistence (Firestore) — only needed if you want daemon
# state (fight history, learned moves/styles, move fitness) to survive a
# fresh container instead of just living in local JSON files. Leave unset
# to keep using local JSON only (default, zero-config behavior).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── In-game "prompt -> unique character" model generation ──────────────────────
# The daemon proxies a text/image -> rigged-GLB generator so the game can build
# one-of-one fighters from a description. Pick ONE path:
#
# 1) OUR OWN forge (preferred): point at a GPU endpoint WE control running an
#    open-source model (TRELLIS / Hunyuan3D + UniRig auto-rig) behind this simple
#    contract:  POST {prompt,rig} -> {glbUrl} (sync) or {id} (async, GET /{id}).
#    Host the model on an HF Space / Modal / RunPod / Replicate (Railway is CPU-only,
#    so run the daemon here and the model on a GPU host). This makes generation
#    fully ours — no third-party API, tunable to our art style.
OWN_GEN_URL=
OWN_GEN_KEY=
#
# 2) Hosted fallback (fastest to test): a third-party API key. Used only if
#    OWN_GEN_URL is unset.
MESHY_API_KEY=
TRIPO_API_KEY=
