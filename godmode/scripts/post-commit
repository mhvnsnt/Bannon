#!/bin/sh
# This script fires autonomously the millisecond a commit is made

echo "[SHADOW LEDGER]: Vectorizin the latest structural changes..."

# Pass the git diff straight to your local autonomous Node
curl -X POST http://localhost:3000/api/armada/shadow-ledger \
     -H "Content-Type: application/json" \
     -d "{\"diff\": \"$(git diff HEAD~1 HEAD)\"}"
